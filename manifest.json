{
    "name": "__MSG_extName__",
    "version": "0.1",
    "icon": {
        "32": "images/icon24.png"
    }
    "description": "Twitter memo application",
    "default_locale": "en",
    "manifest_version": 2,
    "permissions": [
        "storage",
        "webRequest",
        "*://*.twitter.com/"
    ],
    "background": {
        "scripts": [
            "js/background.js"
        ],
        "persistent": true
    },
    "content_scripts": [
        {
            "css": [
                "css/main.css"
            ],
            "matches": [
                "https://*.twitter.com/*"
            ],
            "run_at": "document_end",
            "js": [
                "js/memoOnCard.js",
                "js/memoOnProfile.js"
            ]
        }
    ],
    "page_action": {
        "default_icon": {
            "32": "images/icon24.png"
        },
        "default_title": "Twitter Memo"
    }
}