{
    "name": "Twitter Memo",
    "version": "0.1",
    "description": "Twitter memo application",
    "manifest_version": 2,
    "permissions": [
        "storage",
        "declarativeContent",
        "webRequest",
        "*://*.twitter.com/"
    ],
    "background": {
        "scripts": [
            "background.js"
        ],
        "persistent": true
    },
    "content_scripts": [
        {
            "matches": [
                "https://*.twitter.com/*"
            ],
            "js": [
                "twitterMemo.js"
            ]
        }
    ],
    "page_action": {
        "default_icon": {
            "32": "images/icon24.png"
        },
        "default_title": "Twitter Memo"
    }
}