{
    "name": "Twitter Memo",
    "version": "0.1",
    "description": "Twitter memo application",
    "manifest_version": 2,
    "permissions": [
        "storage",
        "declarativeContent",
        "webRequest",
        "*://*.twitter.com/",
        "https://us-central1-true-ability-250610.cloudfunctions.net/"
    ],
    "background": {
        "scripts": [
            "js/background.js"
        ],
        "persistent": true
    },
    "content_scripts": [
        {
            "css": ["css/main.css"],
            "matches": [
                "https://*.twitter.com/*"
            ],
            "run_at": "document_end",
            "js": [
                "js/memoOnCard.js"
            ]
        },
        {
            "matches": [
                "https://*.twitter.com/*"
            ],
            "run_at": "document_end",
            "js": [
                "js/memoOnProfile.js"
            ]
        }
    ],
    "page_action": {
        "default_icon": {
            "32": "images/icon24.png"
        },
        "default_title": "Twitter Memo"
    },
    "options_page": "static/options.html"
}