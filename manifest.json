{
  "manifest_version": 3,
  "name": "__MSG_extName__",
  "version": "2.0",
  "default_locale": "en",
  "description": "Leave private memos on any X profile",
  "icons": {
    "16": "images/icon16.png",
    "48": "images/icon48.png",
    "128": "images/icon128.png"
  },
  "permissions": ["storage"],
  "action": {
    "default_icon": {
      "16": "images/icon16.png",
      "48": "images/icon48.png"
    },
    "default_title": "Twitter User Memo"
  },
  "background": {
    "service_worker": "js/background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://x.com/*",
        "*://*.x.com/*",
        "*://twitter.com/*",
        "*://*.twitter.com/*"
      ],
      "js": ["js/content.js"],
      "css": ["css/main.css"],
      "run_at": "document_idle"
    }
  ]
}
